  "validation_rules": [
    {
      "rule": "所有parameters必须携带unit字段",
      "check": "terms[*].spec_mapping.type=='parameter' implies spec_mapping.unit != null"
    },
    {
      "rule": "所有limits必须携带unit字段",
      "check": "terms[*].spec_mapping.type=='limit' implies spec_mapping.unit != null"
    },
    {
      "rule": "attrs类型不能有unit",
      "check": "terms[*].spec_mapping.type=='attr' implies spec_mapping.unit == null"
    },
    {
      "rule": "术语必须有source_clause",
      "check": "terms[*].source_clause != null"
    },
    {
      "rule": "confidence必须是high/medium/low之一",
      "check": "terms[*].confidence in ['high', 'medium', 'low']"
    }
  ]
}
