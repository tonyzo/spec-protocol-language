{
  "_schema_version": "1.0",
  "_description": "ASME VIII Boiler and Pressure Vessels - Parameter Mapping Table",
  "_standard": "ASME BPVC Section VIII Division 1",
  
  "standard_info": {
    "name": "ASME Boiler and Pressure Vessel Code Section VIII Division 1",
    "version": "2023",
    "parts": [
