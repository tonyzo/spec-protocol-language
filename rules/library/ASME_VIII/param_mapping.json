  "terms": [
    {
      "term_id": "pressure.design",
      "standard_term": "Design Pressure",
      "definition": "The pressure used in the design of a component, together with any coincident static or dynamic loads",
      "spec_mapping": {
        "type": "parameter",
        "name": "design_pressure",
        "unit": "psi",
        "data_type": "f64"
      },
      "source_clause": "UG-21",
      "referenced_by": ["ASME_VIII-UG-27", "ASME_VIII-UG-32"],
      "related_terms": ["pressure.operating", "pressure.calc"],
      "confidence": "high",
      "synonyms": ["设计压力"],
      "note": "ASME uses psi (pounds per square inch), GB150 uses MPa"
    },
    {
      "term_id": "pressure.operating",
      "standard_term": "Maximum Allowable Working Pressure",
      "definition": "The maximum gauge pressure permissible at the top of a vessel in its normal operating position",
      "spec_mapping": {
        "type": "limit",
        "name": "MAWP",
        "unit": "psi",
        "data_type": "f64"
      },
      "source_clause": "UG-98",
      "referenced_by": ["ASME_VIII-UG-98", "ASME_VIII-UG-99"],
      "related_terms": ["pressure.design", "pressure.test"],
      "confidence": "high",
      "synonyms": ["最高允许工作压力", "MAWP"],
      "note": "ASME uses MAWP, GB150 uses similar concept"
    },
    {
      "term_id": "pressure.test",
      "standard_term": "Test Pressure",
      "definition": "The pressure to which a vessel is subjected during a hydrostatic or pneumatic test",
      "spec_mapping": {
        "type": "parameter",
        "name": "test_pressure",
        "unit": "psi",
        "data_type": "f64"
      },
      "source_clause": "UG-99",
      "referenced_by": ["ASME_VIII-UG-99", "ASME_VIII-UG-100"],
      "related_terms": ["pressure.design", "MAWP"],
      "confidence": "high",
      "synonyms": ["试验压力"]
    },
    {
      "term_id": "temperature.design",
      "standard_term": "Design Temperature",
      "definition": "The temperature of the metal used in the design of a component",
      "spec_mapping": {
        "type": "parameter",
        "name": "design_temperature",
        "unit": "°F",
        "data_type": "f64"
      },
      "source_clause": "UG-20",
      "referenced_by": ["ASME_VIII-UG-23", "ASME_VIII-UG-24"],
      "related_terms": ["temperature.min", "temperature.max"],
      "confidence": "high",
      "synonyms": ["设计温度"],
      "note": "ASME uses °F (Fahrenheit), GB150 uses °C (Celsius)"
    },
    {
      "term_id": "temperature.min",
      "standard_term": "Minimum Design Metal Temperature",
      "definition": "The lowest temperature expected in service",
      "spec_mapping": {
        "type": "limit",
        "name": "MDMT",
        "unit": "°F",
        "data_type": "f64"
      },
      "source_clause": "UG-20",
      "referenced_by": ["ASME_VIII-UG-20", "ASME_VIII-UCS-66"],
      "related_terms": ["temperature.design"],
      "confidence": "high",
      "synonyms": ["最低设计金属温度", "MDMT"],
      "note": "ASME uses MDMT for low temperature assessment"
    },
    {
      "term_id": "thickness.required",
      "standard_term": "Required Thickness",
      "definition": "The minimum thickness of a component calculated by the design formulas",
      "spec_mapping": {
        "type": "limit",
        "name": "delta_calc",
        "unit": "in",
        "data_type": "f64"
      },
      "source_clause": "UG-27",
      "referenced_by": ["ASME_VIII-UG-27", "ASME_VIII-UG-32"],
      "related_terms": ["thickness.nominal", "corrosion.allowance"],
      "confidence": "high",
      "synonyms": ["计算厚度", "所需厚度"],
      "note": "ASME uses inches, GB150 uses mm"
    },
    {
      "term_id": "thickness.nominal",
      "standard_term": "Nominal Thickness",
      "definition": "The thickness to which the material is ordered, including corrosion allowance and mill tolerance",
      "spec_mapping": {
        "type": "parameter",
        "name": "delta",
        "unit": "in",
        "data_type": "f64"
      },
      "source_clause": "UG-25",
      "referenced_by": ["ASME_VIII-UG-25", "ASME_VIII-UG-27"],
      "related_terms": ["thickness.required", "thickness.effective"],
      "confidence": "high",
      "synonyms": ["名义厚度"],
      "note": "ASME nominal thickness includes corrosion allowance + mill tolerance"
    },
    {
      "term_id": "thickness.effective",
      "standard_term": "Effective Thickness",
      "definition": "The nominal thickness minus corrosion allowance and mill tolerance",
      "spec_mapping": {
        "type": "parameter",
        "name": "delta_effective",
        "unit": "in",
        "data_type": "f64"
      },
      "source_clause": "UG-25",
