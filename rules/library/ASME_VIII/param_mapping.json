      "related_terms": ["stress.calc", "R_m", "R_eL"],
      "confidence": "high",
      "synonyms": ["许用应力"],
      "note": "ASME allowable stress from Section II Part D"
    },
    {
      "term_id": "stress.calc",
      "standard_term": "Calculated Stress",
      "definition": "The stress in a component calculated by the design formulas",
      "spec_mapping": {
        "type": "parameter",
        "name": "sigma",
        "unit": "psi",
        "data_type": "f64"
      },
      "source_clause": "UG-27",
